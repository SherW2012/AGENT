# Select one provider: openai, deepseek, or kimi.
BNCT_AGENT_PROVIDER=deepseek

# Configure only the provider keys your team uses. Never commit real values.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# Optional per-provider model overrides.
BNCT_AGENT_OPENAI_MODEL=gpt-5.4-mini
BNCT_AGENT_DEEPSEEK_MODEL=deepseek-v4-pro
BNCT_AGENT_KIMI_MODEL=kimi-k2.6

# Optional: point to an approved enterprise gateway.
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Maximum model/tool turns for one user request.
BNCT_AGENT_MAX_STEPS=12
